# CHUNK_OVERLAP=50

# # LLM Model Configuration
# # Using meta-llama/Llama-2-7b-chat-hf (reliable, works with Hugging Face router)
# # Other working options:
# # LLM_MODEL=gpt2
# # LLM_MODEL=google/flan-t5-base
# LLM_MODEL=openai/gpt-oss-120b:groq


# ////



# ==================== DATABASE ====================
# Docker PostgreSQL Container
DB_HOST=localhost
DB_PORT=5433
DB_NAME=hasuradb
DB_USER=postgres
DB_PASSWORD=postgres

# ==================== HASURA ====================
# Docker Hasura Container
HASURA_URL=http://localhost:8081/v1/graphql
HASURA_ADMIN_SECRET=myadminsecret

# ==================== SERVER ====================
PORT=8000
HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000

# ==================== MINIO ====================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=pdf
MINIO_USE_SSL=false

# ==================== MILVUS ====================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=pdf_embeddings

# ==================== EMBEDDING ====================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
HUGGINGFACE_TOKEN=your_huggingface_token_here

# ==================== LLM ====================

LLM_MODEL=openai/gpt-oss-120b


# ==================== REDIS ====================
 # Redis Cache Configuration (Docker Container)
 REDIS_HOST=localhost
 REDIS_PORT=6379
 REDIS_DB=0
 REDIS_FAQ_TTL_MINUTES=20
 
# ==================== RABBITMQ ====================
 # RabbitMQ Message Broker Configuration (Docker Container)
 RABBITMQ_USER=guest
 RABBITMQ_PASSWORD=guest
 RABBITMQ_HOST=localhost
 RABBITMQ_PORT=5672
 RABBITMQ_VHOST=/
  
# JWT Configuration (change JWT_SECRET_KEY in production!)
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# PDF text chunking configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50